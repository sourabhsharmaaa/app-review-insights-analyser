GROQ_API_KEY=your_groq_api_key_here
APP_ID=com.nextbillion.groww
WEEKS_BACK=12
MAX_REVIEWS=500
MIN_REVIEW_WORDS=5
LOG_LEVEL=INFO
SCRUB_MODE=regex

# Fee Explanation
FEE_FUND_URL=https://groww.in/p/exit-load-in-mutual-funds

# Google Docs — Service Account
GDOC_DOC_ID=your_google_doc_id_here
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service_account.json

# Gmail — OAuth2
GMAIL_CLIENT_SECRET=/path/to/gmail_client_secret.json
GMAIL_TOKEN_PATH=/path/to/gmail_token.json
EMAIL_TO=your_email@gmail.com

# MCP toggle (false = Direct API for production)
USE_MCP=false
